    "Bring your music anywhere, even when you're offline. Your downloaded music will be here." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bring your music anywhere, even when you're offline. Your downloaded music will be here."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bawa musik kamu ke mana saja, bahkan saat kamu sedang offline. Musik yang kamu unduh akan ada di sini."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ta med musikken din hvor som helst, selv når du er frakoblet. Din nedlastede musikk vil være her."
          }
        }
      }
    },

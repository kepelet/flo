    "For now this action means 'Delete all downloaded albums and songs' including its content. Continue?" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For now this action means 'Delete all downloaded albums and songs' including its content. Continue?"
          }
        },
        "id" : {
